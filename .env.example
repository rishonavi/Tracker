# ─────────────────────────────────────────────────────────────
# Offset — environment configuration
# Copy this file to ".env" and fill in your values.
# ─────────────────────────────────────────────────────────────

# Supabase (cloud database + login + receipt storage)
# Create a free project at https://supabase.com, then copy these
# from your project's  Settings → API  page.
# Leave BOTH blank to run the app in local "demo mode" (data is
# stored only in this browser, no login required).
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Currency shown throughout the app (ISO 4217 code). Defaults to INR.
VITE_CURRENCY=INR

# Locale used for number/date formatting. Defaults to en-IN.
VITE_LOCALE=en-IN

# Optional: "Connect Google Drive" backup. Create an OAuth 2.0 Web client in
# Google Cloud (and enable the Google Drive API), then paste its Client ID
# here. Leave blank to hide the Google Drive backup feature.
# Note: Google / Apple SOCIAL LOGIN is configured in the Supabase dashboard,
# not here — see the README.
VITE_GOOGLE_CLIENT_ID=

# Optional: Dropbox backup. Create a "Scoped app" with "App folder" access at
# https://www.dropbox.com/developers (permissions: files.content.read/write),
# add your site URL as an OAuth redirect URI, and paste the App key here.
VITE_DROPBOX_APP_KEY=

# Optional: OneDrive backup. Register an app at https://portal.azure.com
# (platform: SPA; enable implicit "Access tokens"; delegated permission
# Files.ReadWrite.AppFolder), add your site URL as a redirect URI, and paste
# the Application (client) ID here.
VITE_MS_CLIENT_ID=

# Set to "true" to OPEN the app to everyone with NO login (data is stored
# locally in each visitor's browser). Leave blank/false to require login
# whenever Supabase is configured.
VITE_OPEN_ACCESS=
