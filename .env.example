# ─────────────────────────────────────────────────────────────
# Offset — environment configuration
# Copy this file to ".env" and fill in your values.
# ─────────────────────────────────────────────────────────────

# Supabase (cloud database + login + receipt storage)
# Create a free project at https://supabase.com, then copy these
# from your project's  Settings → API  page.
# Leave BOTH blank to run the app in local "demo mode" (data is
# stored only in this browser, no login required).
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Currency shown throughout the app (ISO 4217 code). Defaults to INR.
VITE_CURRENCY=INR

# Locale used for number/date formatting. Defaults to en-IN.
VITE_LOCALE=en-IN

# Optional: Google client ID — powers BOTH "Connect Google Drive" backup AND
# "Import bills from Gmail". Create an OAuth 2.0 Web client in Google Cloud and
# paste its Client ID here. For Drive backup enable the Google Drive API; for
# Gmail import also enable the Gmail API and add the gmail.readonly scope to the
# OAuth consent screen (a Google "restricted" scope — add yourself as a Test
# user). Leave blank to hide both features.
# Note: Google / Apple SOCIAL LOGIN is configured in the Supabase dashboard,
# not here — see the README.
VITE_GOOGLE_CLIENT_ID=

# Optional: Dropbox backup. Create a "Scoped app" with "App folder" access at
# https://www.dropbox.com/developers (permissions: files.content.read/write),
# add your site URL as an OAuth redirect URI, and paste the App key here.
VITE_DROPBOX_APP_KEY=

# Optional: OneDrive backup. Register an app at https://portal.azure.com
# (platform: SPA; enable implicit "Access tokens"; delegated permission
# Files.ReadWrite.AppFolder), add your site URL as a redirect URI, and paste
# the Application (client) ID here.
VITE_MS_CLIENT_ID=

# Set to "true" to OPEN the app to everyone with NO login (data is stored
# locally in each visitor's browser). Leave blank/false to require login
# whenever Supabase is configured.
VITE_OPEN_ACCESS=

# ─────────────────────────────────────────────────────────────
# AI receipt scanning (server-side — runs in the /api function)
# ─────────────────────────────────────────────────────────────
# These are read by the serverless function at api/scan-receipt.js, NOT by the
# browser, so they have NO "VITE_" prefix and are never exposed to the client.
# Set them in your host's dashboard (e.g. Vercel → Project → Settings → Env).
#
# Your Google Gemini API key (FREE — create one at https://aistudio.google.com
# with just a Google account, no credit card). When set, "Scan to auto-fill"
# reads receipts with Gemini's vision model (much more accurate than the
# on-device OCR fallback). Leave blank to keep using the free on-device OCR.
GEMINI_API_KEY=
#
# Optional: override which Gemini model does the scanning. Leave blank to use
# the default (gemini-2.0-flash). Change it if Google renames the free model.
SCAN_MODEL=
